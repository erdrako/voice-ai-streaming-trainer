ENVIRONMENT=docker
LOG_LEVEL=INFO
STT_PROVIDER=faster_whisper_http
LLM_PROVIDER=ollama
TTS_PROVIDER=piper_http
EVENT_BUS_PROVIDER=redis
EVENT_STORE_PROVIDER=sqlite
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
STT_BASE_URL=http://stt:9001
TTS_BASE_URL=http://tts:9002
REDIS_URL=redis://redis:6379/0
DATABASE_PATH=/data/training.db
REQUEST_TIMEOUT_SECONDS=180
STT_TIMEOUT_SECONDS=180
LLM_TIMEOUT_SECONDS=180
TTS_TIMEOUT_SECONDS=180
READINESS_TIMEOUT_SECONDS=3
PROVIDER_RETRY_ATTEMPTS=2
PROVIDER_RETRY_BACKOFF_SECONDS=0.25
PARTIAL_TRANSCRIPTION_MIN_BYTES=120000
PARTIAL_TRANSCRIPTION_EVERY_CHUNKS=4
